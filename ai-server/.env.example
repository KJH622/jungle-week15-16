OPENAI_API_KEY=여기에_OpenAI_API_KEY_입력

# PostgreSQL 연결 — Spring Boot와 같은 DB를 조회합니다.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bulletin_board
DB_USER=postgres
DB_PASSWORD=여기에_비밀번호_입력

# JWT 설정 — Spring application.properties의 jwt.secret과 같은 값을 넣어야 합니다.
JWT_SECRET=여기에_충분히_긴_JWT_시크릿_입력

# GitHub API 토큰은 선택입니다. 없으면 GitHub 비인증 rate limit이 적용됩니다.
GITHUB_TOKEN=

# Agent가 MCP 서버를 호출할 때 사용합니다.
MCP_SERVER_URL=http://localhost:8002/sse

# RAG embedding settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
