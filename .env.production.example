# Docker Compose runtime
HTTP_PORT=80

# PostgreSQL + pgvector
POSTGRES_DB=bulletin_board
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# JWT
# Spring Boot issues tokens and FastAPI validates them, so this value must match.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION=86400000

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_TIMEOUT_SECONDS=30
MCP_TIMEOUT_SECONDS=15
MAX_AGENT_TOOL_ROUNDS=3
MAX_AGENT_TOOL_CALLS=6

# GitHub
# Optional, but recommended to avoid low unauthenticated GitHub API rate limits.
GITHUB_TOKEN=
